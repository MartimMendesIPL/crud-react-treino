{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2020",
        "esModuleInterop": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "jsx": "react"
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"]
}
